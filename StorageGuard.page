  $c_val = array_key_exists($c_key, $cfg) ? $cfg[$c_key] : '';
  if ($w_val !== '' && !empty($pools[$p]) && !in_array($w_val, $pools[$p], true) && !isset($cfg[$w_key])) $w_val = $def['warning'];
  $current_profile = get_btrfs_profile($p);
  $devices_summary = get_pool_devices_summary($pools[$p] ?? []);
?>

