  $safe = preg_replace('/[^a-zA-Z0-9_]/', '_', $p);
  $w_key = "pool_{$safe}_warning";
  $c_key = "pool_{$safe}_critical";
  $w_val = $cfg[$w_key] ?? ($pools[$p][0] ?? '2T');
  $c_val = $cfg[$c_key] ?? ($pools[$p][0] ?? '1T');
?>
<div class="pool-section" id="pool-section-<?=htmlspecialchars($safe)?>" style="margin-bottom:12px; border-left:3px solid #ccc; padding-left:10px;">
  <strong><?=htmlspecialchars($p)?></strong> (Free)

  <div>
    _(Choose <?=htmlspecialchars($p)?> Total Warning Capacity (Free))_:
    : <select name="<?=$w_key?>" id="<?=$w_key?>" class="pool-size-select">
      <?=sg_size_options($pools[$p], $w_val)?>
      </select>
  </div>

  <div>
    _(Choose <?=htmlspecialchars($p)?> Total Critical Capacity (Free))_:
    : <select name="<?=$c_key?>" id="<?=$c_key?>" class="pool-size-select">
      <?=sg_size_options($pools[$p], $c_val)?>
      </select>
  </div>
</div>

<blockquote class="inline_help">
For pool <strong><?=htmlspecialchars($p)?></strong>:<br>
Warning / Critical based on <strong>total free</strong> in the pool.<br><br>
<b>BTRFS RAID awareness examples:</b><br>
- RAID1 (2×1.2T): Losing one drive requires rebalance. Set warning near 1.2T or 2T so you know rebalance may not fit remaining space.<br>
- RAID10 (e.g. 8T+8T+4T+4T+4T+4T): Losing an 8T drive effectively reduces usable by ~4T in many configs. Choose warning/critical so you are warned before a rebalance would fail due to insufficient space.<br><br>
Other BTRFS options (raid5, raid6, raid1c3, raid1c4, raid5e etc.) change the redundancy math. Set thresholds with your RAID profile and rebalance needs in mind. More advanced BTRFS guidance coming soon.
</blockquote>
<?php endforeach; ?>
