<?php foreach ($pool_names as $p): 
  $safe = preg_replace('/[^a-zA-Z0-9_]/', '_', $p);
  $checked = (strpos(','.$pools_to_color.',', ','.$p.',') !== false || $pools_to_color === 'all') ? 'checked' : '';
?>
