<?php
$plugin = "StorageGuard";
$cfg = parse_plugin_cfg($plugin);

// Load disk information from Unraid
$disks_ini = '/var/local/emhttp/disks.ini';
$has_disks = file_exists($disks_ini);
$disks = $has_disks ? parse_ini_file($disks_ini, true) : [];

// Helper: format KB size to human like 26T, 8T, 1.2T, 500G
function sg_format_size($kb) {
    if (!$kb || $kb <= 0) return '0';
    $bytes = $kb * 1024;
    if ($bytes >= 1024 * 1024 * 1024 * 1024) {
        $val = round($bytes / (1024 * 1024 * 1024 * 1024), 1);
        return rtrim(rtrim($val, '0'), '.') . 'T';
    } elseif ($bytes >= 1024 * 1024 * 1024) {
        $val = round($bytes / (1024 * 1024 * 1024), 1);
        return rtrim(rtrim($val, '0'), '.') . 'G';
    } elseif ($bytes >= 1024 * 1024) {
        $val = round($bytes / (1024 * 1024));
        return $val . 'M';
    } else {
        $val = round($bytes / 1024);
        return $val . 'K';
    }
}

// Get current BTRFS profile for a pool (e.g. RAID10, RAID1, RAID5)
function get_btrfs_profile($pool) {
    $mount = "/mnt/" . $pool;
    if (!is_dir($mount)) {
        return "unknown (not mounted?)";
    }
    $cmd = "btrfs fi df " . escapeshellarg($mount) . " 2>/dev/null";
    $output = @shell_exec($cmd);
    if ($output && preg_match('/Data,\s*(\S+):/i', $output, $m)) {
        return $m[1];
    }
    // Fallback to usage for more detail
    $cmd2 = "btrfs fi usage " . escapeshellarg($mount) . " 2>/dev/null | grep -E 'Data,|Metadata,' | head -2";
    $output2 = @shell_exec($cmd2);
    if ($output2) {
        return trim(preg_replace('/\s+/', ' ', $output2));
    }
    return "unknown";
}

function get_btrfs_devices($pool) {
    $mount = "/mnt/" . $pool;
    if (!is_dir($mount)) return [];
    $cmd = "btrfs fi show " . escapeshellarg($mount) . " 2>/dev/null | grep -E 'devid|Size:'";
    $output = @shell_exec($cmd);
    return $output ? "see btrfs fi show" : [];
}

// Simple helper to get list of device sizes for a pool from our collected data
function get_pool_devices_summary($sizes) {
    if (empty($sizes)) return "no devices detected";
    return implode(', ', $sizes);
}

// Unraid naming: pool slots are cache, cache2, mypool, mypool2, ...
function sg_pool_prefix($key) {
    return preg_replace('/\d+$/', '', $key);
}

// Sort human size strings largest-first (26T > 8T > 500G)
function sg_sort_sizes_desc($sizes) {
    $sizes = array_values(array_unique($sizes));
    usort($sizes, function($a, $b) {
        $va = (float)preg_replace('/[^0-9.]/', '', $a);
        $ua = (strpos($a, 'T') !== false) ? 1000 : ((strpos($a, 'G') !== false) ? 1 : 0.001);
        $vb = (float)preg_replace('/[^0-9.]/', '', $b);
        $ub = (strpos($b, 'T') !== false) ? 1000 : ((strpos($b, 'G') !== false) ? 1 : 0.001);
        return ($vb * $ub) <=> ($va * $ua);
    });
    return $sizes;
}

/** solid (default) | outline — prefer per-target key, fall back to legacy global color_style */
function sg_resolve_style($cfg, $key) {
    $legacy = $cfg['color_style'] ?? 'solid';
    $s = $cfg[$key] ?? $legacy;
    return ($s === 'outline') ? 'outline' : 'solid';
}

// Collect array data disk capacities (unique, largest first). Ignore parity / boot / cache.
$array_sizes = [];
$array_raw_sizes = [];
if ($has_disks) {
    foreach ($disks as $key => $d) {
        if (empty($d['device'])) continue;
        $type = isset($d['type']) ? $d['type'] : '';
        $name = isset($d['name']) ? $d['name'] : $key;
        $is_data = ($type === 'Data') || preg_match('/^disk\d+$/', $name) || preg_match('/^disk\d+$/', $key);
        if (!$is_data) continue;
        $sz = isset($d['size']) ? (int)$d['size'] : 0;
        if ($sz > 0) {
            $array_raw_sizes[] = $sz;
            $array_sizes[] = sg_format_size($sz);
        }
    }
}
$array_sizes = sg_sort_sizes_desc($array_sizes);

// Collect pools: only type=Cache, grouped by pool name (prefix of slot key).
$pools = [];
$pools_raw = [];
if ($has_disks) {
    foreach ($disks as $key => $d) {
        if (empty($d['device'])) continue;
        $type = isset($d['type']) ? $d['type'] : '';
        if ($type !== 'Cache') continue;
        $status = isset($d['status']) ? $d['status'] : '';
        if (strpos($status, '_NP') !== false) continue;
        $poolName = sg_pool_prefix($key);
        if ($poolName === '' || $poolName === 'flash') continue;
        $sz = isset($d['size']) ? (int)$d['size'] : 0;
        if ($sz > 0) {
            if (!isset($pools[$poolName])) $pools[$poolName] = [];
            $pools[$poolName][] = sg_format_size($sz);
            if (!isset($pools_raw[$poolName])) $pools_raw[$poolName] = [];
            $pools_raw[$poolName][] = $sz;
        }
    }
}
foreach ($pools as $pname => $sizes) {
    $pools[$pname] = sg_sort_sizes_desc($sizes);
}
ksort($pools, SORT_NATURAL | SORT_FLAG_CASE);
$pool_names = array_keys($pools);

// Dev/preview only when no disks.ini (not Unraid). Real installs always use live pool names.
if (!$has_disks || (empty($array_sizes) && empty($pools))) {
  $array_sizes = ['26T', '12T', '8T', '4T', '2T'];
  $pools = ['cache' => ['2T', '2T']];
  $pool_names = ['cache'];
  $pools_raw = ['cache' => [2000000000, 2000000000]];
  $dev_mode = true;
} else {
  $dev_mode = false;
}

// Array defaults: Warning = largest data disk; Critical = None (user opts in)
$array_defaults = ['warning' => '', 'critical' => ''];
if (!empty($array_raw_sizes)) {
    $sorted = $array_raw_sizes;
    rsort($sorted, SORT_NUMERIC);
    $array_defaults = ['warning' => sg_format_size($sorted[0]), 'critical' => ''];
} elseif (!$has_disks && !empty($array_sizes)) {
    $array_defaults = ['warning' => $array_sizes[0], 'critical' => ''];
}

// Pool defaults: Warning = largest member; Critical = None
$pool_defaults = [];
foreach ($pools_raw as $pname => $raws) {
    if (!empty($raws)) {
        rsort($raws, SORT_NUMERIC);
        $pool_defaults[$pname] = ['warning' => sg_format_size($raws[0]), 'critical' => ''];
    } else {
        $pool_defaults[$pname] = ['warning' => '', 'critical' => ''];
    }
}

// Build <option>s; include leading "None" (empty value = no threshold for that level)
function sg_size_options($sizes, $current, $include_none = true) {
    $html = '';
    if ($include_none) {
        $sel = ($current === '' || $current === null) ? ' selected' : '';
        $html .= '<option value=""' . $sel . '>None</option>';
    }
    $found = ($current === '' || $current === null);
    foreach ($sizes as $s) {
        $sel = ($s === $current) ? ' selected' : '';
        if ($sel) $found = true;
        $html .= '<option value="' . htmlspecialchars($s) . '"' . $sel . '>' . htmlspecialchars($s) . '</option>';
    }
    if (!$found && $current !== '' && $current !== null) {
        $html .= '<option value="' . htmlspecialchars($current) . '" selected>' . htmlspecialchars($current) . '</option>';
    }
    if (empty($sizes) && !$include_none) {
        $html = '<option value="">No disks detected</option>';
    }
    return $html;
}

$array_defaults['critical'] = '';

$array_use_custom = $cfg['array_use_custom'] ?? 'no';
$array_warning_custom = $cfg['array_warning_custom'] ?? '';
$array_critical_custom = $cfg['array_critical_custom'] ?? '';

// Warning: default largest if unset/invalid; empty string only if user chose None
if (array_key_exists('array_warning', $cfg)) {
    $array_warning = $cfg['array_warning'];
    if ($array_use_custom !== 'yes' && $array_warning !== '' && !empty($array_sizes) && !in_array($array_warning, $array_sizes, true)) {
        $array_warning = $array_defaults['warning'] ?? '';
    }
} else {
    $array_warning = $array_defaults['warning'] ?? '';
}
// Critical: default None; keep saved value including empty
if (array_key_exists('array_critical', $cfg)) {
    $array_critical = $cfg['array_critical'];
    if ($array_use_custom !== 'yes' && $array_critical !== '' && !empty($array_sizes) && !in_array($array_critical, $array_sizes, true)) {
        $array_critical = '';
    }
} else {
    $array_critical = '';
}

$array_coloring = $cfg['array_coloring'] ?? 'yes';
$pool_coloring = $cfg['pool_coloring'] ?? $cfg['cache_coloring'] ?? 'yes';
$array_color_style = sg_resolve_style($cfg, 'array_color_style');
$outline_pulse = (($cfg['outline_pulse'] ?? 'no') === 'yes') ? 'yes' : 'no';
$outline_show_ok = (($cfg['outline_show_ok'] ?? 'no') === 'yes') ? 'yes' : 'no';

$pools_to_color = $cfg['pools_to_color'] ?? 'all';  // 'all' or comma list

// --- Alerts: per-target severity (warning / critical independently) ---
$legacy_alerts_on = ($cfg['alerts_enabled'] ?? 'yes') === 'yes';
$legacy_warn = ($cfg['warning_alerts_enabled'] ?? 'yes') === 'yes';
$legacy_crit = ($cfg['critical_alerts_enabled'] ?? 'yes') === 'yes';
$legacy_for = $cfg['alerts_for'] ?? 'all';

function sg_alert_default($cfg, $key, $legacy_on, $legacy_level_on, $legacy_for, $target) {
    if (isset($cfg[$key])) return $cfg[$key];
    if (!$legacy_on || !$legacy_level_on) return 'no';
    if ($legacy_for === 'all') return 'yes';
    $list = array_map('trim', explode(',', $legacy_for));
    return in_array($target, $list, true) ? 'yes' : 'no';
}

$has_array_disks = !empty($array_raw_sizes);
$alerts_array_warning = sg_alert_default($cfg, 'alerts_array_warning', $legacy_alerts_on, $legacy_warn, $legacy_for, 'array');
$alerts_array_critical = sg_alert_default($cfg, 'alerts_array_critical', $legacy_alerts_on, $legacy_crit, $legacy_for, 'array');
if (!$has_array_disks && !isset($cfg['alerts_array_warning'])) $alerts_array_warning = 'no';
if (!$has_array_disks && !isset($cfg['alerts_array_critical'])) $alerts_array_critical = 'no';

$pool_alert_cfg = [];
foreach ($pool_names as $p) {
    $safe = preg_replace('/[^a-zA-Z0-9_]/', '_', $p);
    $pool_alert_cfg[$p] = [
        'safe' => $safe,
        'warning' => sg_alert_default($cfg, "alerts_pool_{$safe}_warning", $legacy_alerts_on, $legacy_warn, $legacy_for, $p),
        'critical' => sg_alert_default($cfg, "alerts_pool_{$safe}_critical", $legacy_alerts_on, $legacy_crit, $legacy_for, $p),
    ];
}
?>

