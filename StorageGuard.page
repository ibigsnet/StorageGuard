<?php
$plugin = "storageguard";
$cfg = parse_plugin_cfg($plugin);

// Load disk information from Unraid
$disks_ini = '/var/local/emhttp/disks.ini';
$has_disks = file_exists($disks_ini);
$disks = $has_disks ? parse_ini_file($disks_ini, true) : [];

// Helper: format KB size to human like 26T, 8T, 1.2T, 500G
function sg_format_size($kb) {
    if (!$kb || $kb <= 0) return '0';
    $bytes = $kb * 1024;
    if ($bytes >= 1024 * 1024 * 1024 * 1024) {
        $val = round($bytes / (1024 * 1024 * 1024 * 1024), 1);
        return rtrim(rtrim($val, '0'), '.') . 'T';
    } elseif ($bytes >= 1024 * 1024 * 1024) {
        $val = round($bytes / (1024 * 1024 * 1024), 1);
        return rtrim(rtrim($val, '0'), '.') . 'G';
    } elseif ($bytes >= 1024 * 1024) {
        $val = round($bytes / (1024 * 1024));
        return $val . 'M';
    } else {
        $val = round($bytes / 1024);
        return $val . 'K';
    }
}

// Collect array data disk capacities (unique, largest first). Ignore parity.
$array_sizes = [];
if ($has_disks) {
    foreach ($disks as $key => $d) {
        if (empty($d['device'])) continue;
        $name = isset($d['name']) ? $d['name'] : $key;
        if (preg_match('/^disk\d+$/', $name)) {
            $sz = isset($d['size']) ? (int)$d['size'] : 0;
            if ($sz > 0) {
                $array_sizes[] = sg_format_size($sz);
            }
        }
    }
}
$array_sizes = array_unique($array_sizes);
// Sort descending by numeric value (rough parse)
usort($array_sizes, function($a, $b) {
    $va = (float)preg_replace('/[^0-9.]/', '', $a);
    $ua = strpos($a, 'T') !== false ? 1000 : (strpos($a,'G')!==false ? 1 : 0.001);
    $vb = (float)preg_replace('/[^0-9.]/', '', $b);
    $ub = strpos($b, 'T') !== false ? 1000 : (strpos($b,'G')!==false ? 1 : 0.001);
    return ($vb * $ub) <=> ($va * $ua);
});

// Collect pools + their disk sizes
// Pools are non-disk, non-parity, non-flash entries. Use section key (or name) as pool identifier.
$pools = [];
if ($has_disks) {
    foreach ($disks as $key => $d) {
        if (empty($d['device'])) continue;
        // Skip array data disks and parity
        if (preg_match('/^disk\d+$/', $key) || strpos($key, 'parity') === 0 || $key === 'flash') {
            continue;
        }
        // Pool name: prefer section key (e.g. "cache", "intelligence"), fall back to name field
// This ensures we list actual pools, not individual disk devices.
        $poolName = $key;
        if (isset($d['name']) && !empty(trim($d['name']))) {
            $poolName = trim($d['name']);
        }
        $sz = isset($d['size']) ? (int)$d['size'] : 0;
        if ($sz > 0) {
            if (!isset($pools[$poolName])) $pools[$poolName] = [];
            $pools[$poolName][] = sg_format_size($sz);
        }
    }
}
// Unique + sort per pool
foreach ($pools as $pname => $sizes) {
    $pools[$pname] = array_unique($sizes);
    usort($pools[$pname], function($a, $b) {
        $va = (float)preg_replace('/[^0-9.]/', '', $a);
        $ua = strpos($a, 'T') !== false ? 1000 : (strpos($a,'G')!==false ? 1 : 0.001);
        $vb = (float)preg_replace('/[^0-9.]/', '', $b);
        $ub = strpos($b, 'T') !== false ? 1000 : (strpos($b,'G')!==false ? 1 : 0.001);
        return ($vb * $ub) <=> ($va * $ua);
    });
}

$pool_names = array_keys($pools);

// Dev/preview fallback so the UI is usable even without a real Unraid disks.ini
if (!$has_disks || (empty($array_sizes) && empty($pools))) {
  $array_sizes = ['26T', '12T', '8T', '4T', '2T'];
  $pools = [
    'intelligence' => ['1.2T'],
    'overshield' => ['8T', '4T'],
    'hyperspace' => ['2T'],
  ];
  $pool_names = array_keys($pools);
  $dev_mode = true;
} else {
  $dev_mode = false;
}

// Helper to build <option>s for a size list (current value preselected)
function sg_size_options($sizes, $current) {
    $html = '';
    $found = false;
    foreach ($sizes as $s) {
        $sel = ($s === $current) ? ' selected' : '';
        if ($sel) $found = true;
        $html .= '<option value="' . htmlspecialchars($s) . '"' . $sel . '>' . htmlspecialchars($s) . '</option>';
    }
    if (!$found && $current) {
        // keep custom-ish previous value visible
        $html = '<option value="' . htmlspecialchars($current) . '" selected>' . htmlspecialchars($current) . '</option>' . $html;
    }
    if (empty($sizes)) {
        $html = '<option value="">No disks detected</option>';
    }
    return $html;
}

// Current values (fallbacks)
$array_warning = $cfg['array_warning'] ?? '8T';
$array_critical = $cfg['array_critical'] ?? '2T';
$array_use_custom = $cfg['array_use_custom'] ?? 'no';
$array_warning_custom = $cfg['array_warning_custom'] ?? '';
$array_critical_custom = $cfg['array_critical_custom'] ?? '';

$array_coloring = $cfg['array_coloring'] ?? 'yes';
$pool_coloring = $cfg['pool_coloring'] ?? $cfg['cache_coloring'] ?? 'yes';

$pools_to_color = $cfg['pools_to_color'] ?? 'all';  // 'all' or comma list
$alerts_enabled = $cfg['alerts_enabled'] ?? 'yes';
$alerts_for = $cfg['alerts_for'] ?? 'all';
?>

