  <?=mk_option($array_use_custom, "no", _("No"))?>
  <?=mk_option($array_use_custom, "yes", _("Yes"))?>
  </select>

<blockquote class="inline_help">
Yes = ignore the disk dropdowns above and use the manual values below instead. Useful for fine-tuned values not exactly matching a disk size (e.g. 7.5T, 1.5T, 500G).
